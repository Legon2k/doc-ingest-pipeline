# ------------------------------------------------------------
# Local Ollama instance — vision & fast inference
# ------------------------------------------------------------
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_KEY=ollama
#VISION_MODEL=minicpm-v:latest
VISION_MODEL=GLM-OCR
# Vision API mode: false = /v1/chat/completions (default), true = /api/chat (native Ollama).
# Use true if the model ignores num_ctx via the OpenAI-compatible endpoint.
LOCAL_LLM_CHAT_MODE=true
# Timeout for vision OCR requests in seconds (default: 180)
LOCAL_LLM_TIMEOUT=180
# Ollama context window for vision requests. Raise if you hit exceed_context_size_error.
LOCAL_LLM_NUM_CTX=8192
# Local text model used for vacancy profile compression (extract_vacancy_profile).
LOCAL_TEXT_MODEL=gemma4:e4b
# Run the vacancy compression stage before resume tailoring.
# false = raw OCR text goes directly to the cloud model (faster, uses more context).
# true  = compression stage strips fluff first (protects context window).
USE_VACANCY_EXTRACTION=false

# ------------------------------------------------------------
# Cloud / reasoning model
# Temporarily routed to local Ollama for development.
# Swap CLOUD_LLM_URL + CLOUD_LLM_KEY for AWS Bedrock or
# OpenRouter when ready for production.
# ------------------------------------------------------------
CLOUD_LLM_URL=http://localhost:11434/v1
CLOUD_LLM_KEY=ollama
CLOUD_TEXT_MODEL=gemma4:e4b
# Timeout for cloud reasoning requests in seconds (default: 1800)
CLOUD_LLM_TIMEOUT=1800

# ------------------------------------------------------------
# Storage paths
# ------------------------------------------------------------
GOOGLE_DRIVE_PATH=/path/to/your/google/drive
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# Resume templates directory.
# Falls back to ./templates (repo root) if not set.
TEMPLATES_DIR=./templates

# Vacancies directory.
# Falls back to ./vacancies (repo root) if not set.
VACANCIES_DIR=./vacancies
